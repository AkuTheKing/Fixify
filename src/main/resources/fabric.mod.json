{
	"schemaVersion": 1,
	"id": "fixify",
	"version": "${version}",
	"name": "Fixify",
	"icon": "icon.png",
	"description": "A configurable client-side Hypixel SkyBlock utility mod with dungeon tools, visual customization, HUD overlays, performance improvements, reminders, and quality-of-life fixes.",
	"authors": [
		"Fixify"
	],
	"contributors": [
		"next_g (Skylens feature design)",
		"Tytoyos (GibCoins feature implementations)",
		"SkyCeleste (feature implementations)",
		"odtheking (Odin feature implementations)",
		"DayReminder project (feature implementation)"
	],
	"license": "GPL-3.0-only",
	"environment": "client",
  "entrypoints": {
    "client": [
      "dev.fixify.client.FixifyClient"
    ]
  },
  "mixins": [
    "fixify.mixins.json"
  ],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
